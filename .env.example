# Investment Agent local deployment settings.
# Copy to .env and fill the values that are specific to your machine.

COMPOSE_PROJECT_NAME=investment-agent

# Host ports. The web UI is the normal entry point.
INVESTMENT_AGENT_WEB_PORT=4173
INVESTMENT_AGENT_SERVER_PORT=8080

# Persistent local data directory. install.sh rewrites this to an absolute path.
INVESTMENT_AGENT_DATA_DIR=.investment-agent

# LLM configuration. Keep the real key only in your local .env or secret store.
DEEPSEEK_API_KEY=
# Optional: mount or otherwise provide a local file that contains only the key.
# DEEPSEEK_API_KEY takes precedence when both are set.
DEEPSEEK_API_KEY_FILE=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30

# Embedding configuration for real sqlite-vec semantic retrieval.
# This is separate from the chat/analysis model above and must use an embeddings endpoint.
INVESTMENT_AGENT_EMBEDDING_ENABLED=false
INVESTMENT_AGENT_EMBEDDING_PROVIDER=openai_compatible
INVESTMENT_AGENT_EMBEDDING_API_KEY=
INVESTMENT_AGENT_EMBEDDING_BASE_URL=
INVESTMENT_AGENT_EMBEDDING_MODEL=
INVESTMENT_AGENT_EMBEDDING_DIMENSIONS=1536
INVESTMENT_AGENT_EMBEDDING_TIMEOUT_SECONDS=60

# Runtime behavior.
INVESTMENT_AGENT_RUNTIME_MODE=release
INVESTMENT_AGENT_LOG_LEVEL=info
INVESTMENT_AGENT_USE_STUB_DATA=false
